% neurips_2024.sty - NeurIPS 2024 conference style
% Minimal working version for Overleaf compilation

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 submission/camera-ready style file]

% Declare options
\newif\if@neuripsfinal\@neuripsfinalfalse
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripsfinaltrue}
\ProcessOptions\relax

% Page layout
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
  \@ifpackageloaded{fullpage}
    {\PackageWarning{neurips_2024}{fullpage package not allowed! Overriding page geometry.}}
    {}
}

% Fonts and encoding
\RequirePackage{times}

% Title formatting
\renewcommand{\maketitle}{%
  \par
  \begingroup
    \renewcommand{\thefootnote}{\fnsymbol{footnote}}
    \def\@makefnmark{\hbox to\z@{$\m@th^{\@thefnmark}$\hss}}
    \long\def\@makefntext##1{\parindent 1em\noindent
      \hbox to1.8em{\hss$\m@th^{\@thefnmark}$}##1}
    \@maketitle
    \@thanks
  \endgroup
  \setcounter{footnote}{0}
  \let\maketitle\relax \let\@maketitle\relax
  \gdef\@thanks{}\gdef\@author{}\gdef\@title{}\let\thanks\relax
}

\def\@maketitle{%
  \newpage
  \null
  \vskip 2em
  \begin{center}
    {\LARGE \@title \par}
    \vskip 1.5em
    {\large
      \lineskip .5em
      \begin{tabular}[t]{c}
        \@author
      \end{tabular}\par}
  \end{center}
  \par
  \vskip 1.5em
}

% Abstract
\renewenvironment{abstract}%
  {\centerline{\large\bf Abstract}\vspace{0.7ex}\begin{quote}}
  {\par\end{quote}\vskip 1ex}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bf\raggedright}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bf\raggedright}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\it\raggedright}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{10pt}{4pt}
\titlespacing*{\subsection}{0pt}{8pt}{2pt}
\titlespacing*{\subsubsection}{0pt}{6pt}{0pt}

% Bibliography
\bibliographystyle{plainnat}
\renewcommand{\bibsection}{\section*{References}}

% Hyperref setup (if loaded)
\AtBeginDocument{
  \@ifpackageloaded{hyperref}{
    \hypersetup{
      colorlinks=true,
      linkcolor=blue,
      citecolor=blue,
      urlcolor=blue
    }
  }{}
}

% Line spacing
\RequirePackage{setspace}
\setstretch{1.0}

% Final mode adjustments
\if@neuripsfinal
  \newcommand{\neurips

finalcopy}[0]{}
\fi

\endinput
